---
// Places a tent in the scene: --row-* and --angle drive the hero-arc→header-line
// fly (via --bend in header.css); the tent geometry comes in through the slot.
interface Props {
  rowY: number;
  angle: number;
  rowX?: number;
  rowZ?: number;
  heroOnly?: boolean;
}
const { rowY, angle, rowX = 0, rowZ = 0, heroOnly = false } = Astro.props;

const vars = [
  `--row-x:${rowX}px`,
  `--row-y:${rowY}px`,
  `--row-z:${rowZ}px`,
  `--angle:${angle}deg`,
];
---

<div class:list={["tent-position", { "hero-only": heroOnly }]} style={vars.join(";")}>
  <slot />
</div>
