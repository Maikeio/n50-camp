---
import "../styles/global.css";
import Tents from "../generated/Tents";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>tents.stl — CSS 3D</title>
  </head>
  <body>
    <!-- scene owns the perspective (FOV); camera is the orbit/dolly rig.
         Every tent is the same <Tent> component; the four small ones share one
         deduplicated prototype (prototypes.length is 2, instances.length is 5). -->
    <div id="scene">
      <div id="camera">
        <Tents />
      </div>
    </div>

    <div id="panel">
      <h1>camera</h1>
      <div id="controls"></div>
      <button id="reset">reset</button>
    </div>

    <script>
      // The only runtime JS: copy slider values into CSS custom properties.
      // No 3D math — every transform is baked into the static HTML at build time.
      interface Knob {
        key: string;
        label: string;
        unit: string;
        min: number;
        max: number;
        step: number;
      }

      const KNOBS: Knob[] = [
        { key: "fov", label: "FOV (perspective)", unit: "px", min: 300, max: 4000, step: 10 },
        { key: "rotX", label: "rotate X", unit: "deg", min: -180, max: 180, step: 1 },
        { key: "rotY", label: "rotate Y", unit: "deg", min: -180, max: 180, step: 1 },
        { key: "rotZ", label: "rotate Z", unit: "deg", min: -180, max: 180, step: 1 },
        { key: "panX", label: "pan X", unit: "px", min: -800, max: 800, step: 1 },
        { key: "panY", label: "pan Y", unit: "px", min: -800, max: 800, step: 1 },
        { key: "dist", label: "dolly Z", unit: "px", min: -2000, max: 1500, step: 5 },
        { key: "zoom", label: "zoom", unit: "", min: 0.1, max: 4, step: 0.01 },
      ];

      const SAVE = "tent-camera";
      const root = document.documentElement;
      const css = getComputedStyle(root);
      const controls = document.getElementById("controls");
      const resetBtn = document.getElementById("reset");

      if (controls && resetBtn) {
        const saved: Record<string, number> = JSON.parse(localStorage.getItem(SAVE) ?? "{}");

        for (const knob of KNOBS) {
          const fallback = parseFloat(css.getPropertyValue(`--${knob.key}`));
          const value = knob.key in saved ? saved[knob.key] : fallback;

          const wrap = document.createElement("div");
          wrap.className = "ctl";
          const label = document.createElement("label");
          const name = document.createElement("span");
          name.textContent = knob.label;
          const val = document.createElement("span");
          val.className = "val";
          label.append(name, val);

          const input = document.createElement("input");
          input.type = "range";
          input.min = String(knob.min);
          input.max = String(knob.max);
          input.step = String(knob.step);
          input.value = String(value);

          const reflect = (): void => {
            val.textContent = input.value + knob.unit;
            root.style.setProperty(`--${knob.key}`, `${input.value}${knob.unit}`);
          };
          input.addEventListener("input", () => {
            reflect();
            saved[knob.key] = parseFloat(input.value);
            localStorage.setItem(SAVE, JSON.stringify(saved));
          });

          wrap.append(label, input);
          controls.appendChild(wrap);
          reflect();
        }

        resetBtn.addEventListener("click", () => {
          localStorage.removeItem(SAVE);
          location.reload();
        });
      }
    </script>
  </body>
</html>
